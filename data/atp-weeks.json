  "milestones": [
    { "t": 1973.65, "title": "Nastase tops the first rankings", "text": "The ATP computer rankings debut on 23 Aug 1973 with Ilie Nastase as the inaugural world No. 1." },
    { "t": 1974.6, "title": "Connors begins 160-week reign", "text": "Jimmy Connors takes No. 1 in July 1974 and holds it for 160 straight weeks — a record streak until Federer." },
    { "t": 1985.7, "title": "Lendl's machine era", "text": "Ivan Lendl starts a 157-week unbroken run in Sep 1985 on his way to 270 career weeks at the top." },
    { "t": 1996.5, "title": "Sampras owns the 90s", "text": "Pete Sampras stacks up six straight year-end No. 1 finishes (1993–98) en route to 286 weeks." },
    { "t": 2004.1, "title": "Federer era begins", "text": "Roger Federer seizes No. 1 in Feb 2004 and keeps it for a record 237 consecutive weeks through Aug 2008." },
    { "t": 2021.17, "title": "Djokovic passes Federer", "text": "In March 2021 Novak Djokovic logs his 311th week at No. 1, breaking Federer's all-time record of 310." },
    { "t": 2024.45, "title": "Sinner ends the Big-3 era", "text": "Jannik Sinner becomes Italy's first world No. 1 in June 2024 — the first new-generation player to lead since 2004." }
