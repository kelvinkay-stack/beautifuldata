  "milestones": [
    {
      "t": 1883.4,
      "title": "Brooklyn Bridge opens",
      "text": "Roebling's 486 m span across the East River is the world's first steel-wire suspension bridge — and by far its longest."
    },
    {
      "t": 1931.8,
      "title": "George Washington doubles the record",
      "text": "At 1,067 m, the George Washington Bridge nearly doubles the Ambassador's 564 m — the biggest single leap in span history."
    },
    {
      "t": 1937.4,
      "title": "Golden Gate Bridge",
      "text": "The 1,280 m span in international orange begins a 27-year reign as the world's longest — and its most photographed."
    },
    {
      "t": 1964.9,
      "title": "Verrazzano-Narrows",
      "text": "New York reclaims the record at 1,298 m — the last time an American bridge will hold the title."
    },
    {
      "t": 1998.3,
      "title": "Akashi Kaikyō: 1,991 m",
      "text": "Japan's Pearl Bridge shatters the record by over 500 m. The 1995 Kobe earthquake shifted its towers, stretching the span by a metre."
    },
    {
      "t": 2022.2,
      "title": "Çanakkale takes it to Europe",
      "text": "Turkey's Çanakkale 1915 Bridge spans the Dardanelles at 2,023 m — the first past two kilometres, ending Akashi's 24-year reign."
    }
  ]
