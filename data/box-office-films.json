  "milestones": [
    {
      "t": 1966.5,
      "title": "Sound of Music takes No. 1",
      "text": "Julie Andrews' musical ends Gone with the Wind's 26-year reign — until GWTW's 1967 70mm re-release wins the crown right back."
    },
    {
      "t": 1976.2,
      "title": "Jaws invents the blockbuster",
      "text": "Spielberg's shark devours Gone with the Wind's decades-old record and creates the summer event movie."
    },
    {
      "t": 1983.1,
      "title": "E.T. phones past Star Wars",
      "text": "Spielberg beats his friend Lucas: E.T. overtakes Star Wars to become the highest-grossing film ever."
    },
    {
      "t": 1994,
      "title": "Jurassic Park takes the crown",
      "text": "Dinosaurs stomp past E.T. — Spielberg replaces himself at No. 1 for the second time."
    },
    {
      "t": 1998.25,
      "title": "Titanic breaks $1 billion",
      "text": "The first film ever to gross $1B worldwide, on the way to an unthinkable $1.84B initial run."
    },
    {
      "t": 2010.15,
      "title": "Avatar dethrones Titanic",
      "text": "James Cameron beats James Cameron: Avatar passes Titanic after just seven weeks, headed for $2.7B."
    },
    {
      "t": 2019.6,
      "title": "Endgame edges past Avatar",
      "text": "After a record $1.2B opening weekend, Avengers: Endgame overtakes Avatar by a whisker — $2.798B to $2.790B."
    },
    {
      "t": 2021.2,
      "title": "Avatar strikes back",
      "text": "A China re-release nudges Avatar past Endgame to reclaim No. 1, a crown it still holds at $2.92B."
    }
  ]
