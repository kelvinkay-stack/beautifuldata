  "milestones": [
    {
      "t": 1930.4,
      "title": "Chrysler's secret spire",
      "text": "A 38 m spire assembled inside the Chrysler Building is hoisted into place, snatching the world title from rival 40 Wall Street."
    },
    {
      "t": 1931.3,
      "title": "Empire State Building",
      "text": "Built in just 13 months, the 381 m Empire State Building begins a record 40-year reign as the world's tallest."
    },
    {
      "t": 1972,
      "title": "WTC ends a 40-year reign",
      "text": "The World Trade Center's North Tower (417 m) finally dethrones the Empire State Building."
    },
    {
      "t": 1973.5,
      "title": "Sears Tower tops out",
      "text": "Chicago's 442 m Sears (now Willis) Tower takes the crown barely a year later and holds it for a quarter century."
    },
    {
      "t": 1998,
      "title": "Petronas controversy",
      "text": "Petronas' spires edge out Sears' roof, 452 m to 442 m. CTBUH rules spires count toward height — antennas don't."
    },
    {
      "t": 2004,
      "title": "Taipei 101",
      "text": "At 508 m, Taipei 101 is the first building past the half-kilometre mark."
    },
    {
      "t": 2010,
      "title": "Burj Khalifa: 828 m",
      "text": "Dubai's Burj Khalifa obliterates every record, standing 320 m taller than the previous champion — a gap unmatched in history."
    },
    {
      "t": 2023,
      "title": "Merdeka 118",
      "text": "Kuala Lumpur's 679 m Merdeka 118 becomes the world's second-tallest building, 25 years after Petronas held the top spot."
    }
  ]
}
