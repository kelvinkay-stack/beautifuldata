  "milestones": [
    { "t": -600, "title": "Babylon, first to 200,000", "text": "Nebuchadnezzar II rebuilds Babylon with its ziggurat and hanging gardens — the first city believed to reach roughly 200,000 people." },
    { "t": 100, "title": "Rome hits one million", "text": "Fed by grain fleets and eleven aqueducts, imperial Rome reaches about a million people — a size no city matches again for 1,700 years." },
    { "t": 550, "title": "The fall of Rome", "text": "Sacks, plague and cut aqueducts empty the old capital. Rome dwindles toward 30,000 — a ghost town camped in ruins built for a million." },
    { "t": 900, "title": "Baghdad's golden age", "text": "The Abbasid round city, home of the House of Wisdom, peaks near 900,000 — the largest city on Earth at the height of the Islamic Golden Age." },
    { "t": 1275, "title": "Song China's urban explosion", "text": "Hangzhou — Marco Polo's 'Quinsai' — nears a million as Song China's commercial revolution builds the biggest cities of the medieval world." },
    { "t": 1825, "title": "London passes Beijing", "text": "Around 1825 industrial London overtakes Beijing as the world's largest city — the first time the top spot leaves Asia in a millennium." },
    { "t": 1900, "title": "The industrial megacity", "text": "Steam, rail and empire swell London to 6.5 million by 1900 — triple anything history had seen and the dawn of the modern megacity." }
