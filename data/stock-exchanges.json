  "milestones": [
    { "t": 1988.9, "title": "Tokyo overtakes NYSE", "text": "At the height of Japan's asset bubble, shares listed in Tokyo are worth more than New York's — the only time the NYSE has been dethroned." },
    { "t": 1990.2, "title": "The bubble bursts", "text": "The Nikkei sheds nearly 40% in 1990 alone. Tokyo's market value collapses and the NYSE retakes #1 within two years — for good." },
    { "t": 2000.2, "title": "Nasdaq's dot-com peak", "text": "Dot-com mania swells Nasdaq to about $6.6T in March 2000. Within two years, roughly three quarters of that value evaporates." },
    { "t": 2007.6, "title": "China's exchanges surge", "text": "A frenzied 2007 rally multiplies Shanghai's market value roughly tenfold in two years as retail investors pile in." },
    { "t": 2008.7, "title": "The global financial crisis", "text": "The 2008 crash wipes out roughly 40% of world market value; the NYSE alone loses over $6T in a year." },
    { "t": 2015.45, "title": "China's margin bubble pops", "text": "Shanghai and Shenzhen peak near a combined $10T in June 2015, then lose a third of it in one summer as the margin bubble deflates." },
    { "t": 2024.1, "title": "India enters the top four", "text": "India's NSE sails past Hong Kong, making India's market the world's fourth most valuable after the US, China and Japan." }
