  "milestones": [
    {
      "t": 1993.45,
      "title": "The TOP500 era begins",
      "text": "The first TOP500 list crowns Los Alamos' Thinking Machines CM-5 at 59.7 gigaflops."
    },
    {
      "t": 1997.45,
      "title": "First teraflop: ASCI Red",
      "text": "Sandia's Intel-built ASCI Red breaks the trillion-operations barrier, kicking off a decade of US dominance."
    },
    {
      "t": 2002.45,
      "title": "Earth Simulator shock",
      "text": "Japan's Earth Simulator debuts at 35.9 TFLOPS, nearly 5x the previous champion — dubbed 'Computenik' in Washington."
    },
    {
      "t": 2008.45,
      "title": "First petaflop: Roadrunner",
      "text": "Los Alamos' hybrid Cell-processor Roadrunner crosses the petaflop line, a thousandfold gain in 11 years."
    },
    {
      "t": 2011.45,
      "title": "K computer takes the crown",
      "text": "Riken's K computer returns Japan to #1 at 8.2 PFLOPS, more than the next five systems combined."
    },
    {
      "t": 2016.45,
      "title": "Sunway TaihuLight",
      "text": "China's 93 PFLOPS TaihuLight tops the list using entirely home-grown processors."
    },
    {
      "t": 2022.45,
      "title": "First exaflop: Frontier",
      "text": "Oak Ridge's Frontier breaks the exascale barrier at 1.1 EFLOPS — a quintillion calculations per second."
    },
    {
      "t": 2025.45,
      "title": "El Capitan: 1.74 EFLOPS",
      "text": "Lawrence Livermore's El Capitan takes #1, giving the US the top three exascale machines."
    }
  ]
