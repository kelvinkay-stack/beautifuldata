    { "t": 1991.9, "title": "Pan Am's final flight", "text": "America's flag carrier collapses in December 1991, months after selling its Atlantic routes to Delta." },
    { "t": 1992.2, "title": "Aeroflot shatters", "text": "The USSR's breakup splits the world's largest airline (~137M pax in 1990) into hundreds of regional 'babyflots'." },
