  "milestones": [
    { "t": 1972.5, "title": "Fischer's 2785", "text": "Fresh off crushing the Candidates, Bobby Fischer posts 2785 — a rating summit nobody touches for the next 18 years." },
    { "t": 1985.85, "title": "Kasparov, youngest champion", "text": "At 22, Garry Kasparov dethrones Karpov in Moscow to become the youngest world chess champion in history." },
    { "t": 1990.05, "title": "Kasparov breaks Fischer's record", "text": "The January 1990 list shows Kasparov at 2800 — past Fischer's 2785 at last, and the first rating ever to start with a 28." },
    { "t": 1999.5, "title": "Kasparov peaks at 2851", "text": "On the July 1999 list Kasparov reaches 2851, a mark that stands as the all-time record for 14 years." },
    { "t": 2013.05, "title": "Carlsen tops Kasparov's mark", "text": "Magnus Carlsen opens 2013 rated 2861, finally overtaking Kasparov's 2851 — and he is only getting started." },
    { "t": 2014.4, "title": "Carlsen's all-time record: 2882", "text": "In May 2014 Carlsen hits 2882, the highest rating ever published. More than a decade later, no one has come close." },
    { "t": 2024.92, "title": "Gukesh, youngest world champion", "text": "In December 2024, 18-year-old Gukesh Dommaraju beats Ding Liren in Singapore to become the youngest world champion ever." }
