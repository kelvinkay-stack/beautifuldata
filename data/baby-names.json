  "milestones": [
    { "t": 1921, "title": "Peak Mary", "text": "73,983 girls are named Mary in 1921 — a single-year record no name will top until Linda's brief explosion a generation later." },
    { "t": 1947, "title": "The Linda earthquake", "text": "Jack Lawrence's hit song 'Linda' powers 99,693 Lindas — the biggest one-name spike ever recorded — ending Mary's 47-year reign." },
    { "t": 1953, "title": "Mary retakes the crown", "text": "The Linda wave recedes as fast as it rose. Mary reclaims No. 1 and holds it through 1961 — her final years on top." },
    { "t": 1962, "title": "Lisa ends the old order", "text": "Lisa dethrones Mary for good. No name from the 1900s establishment will ever hold No. 1 again." },
    { "t": 1970, "title": "The Jennifer era begins", "text": "Jennifer opens a 15-year reign at No. 1, peaking near 63,000 in 1974 — then crashes to under 1,000 a year by the 2020s." },
    { "t": 1991, "title": "Ashley snatches the crown", "text": "After trailing Jessica for six years, Ashley takes No. 1 in 1991-92 — then Jessica grabs it right back. The great 90s duel." },
    { "t": 1996, "title": "Emily's quiet dozen years", "text": "Emily begins 12 straight years at No. 1 — but with barely 26,000 births at her peak, as American naming grows ever more diverse." },
    { "t": 2019, "title": "Olivia takes over", "text": "Olivia passes Emma and holds No. 1 through 2024 — with about 15,000 babies a year, a fraction of what Linda once drew." }
  ]
}
