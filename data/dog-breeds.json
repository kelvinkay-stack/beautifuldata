  "milestones": [
    { "t": 1936, "title": "The Cocker Spaniel era begins", "text": "The merry Cocker overtakes the Boston Terrier and starts a 17-year run as America's favorite, peaking near 78,500 registrations in 1947." },
    { "t": 1953, "title": "Beagle's turn on top", "text": "The Beagle ends the Cocker's long first reign and holds No. 1 through the late 1950s — the start of seven decades inside the top ten." },
    { "t": 1960, "title": "Poodle takes No. 1", "text": "The Poodle starts a 22-year reign at No. 1, riding a midcentury glamour craze to registration numbers no breed had ever seen." },
    { "t": 1984, "title": "The Cocker comeback", "text": "Four decades after its first reign, the Cocker Spaniel dethrones the Poodle and rules again through 1990." },
    { "t": 1991, "title": "The Labrador era begins", "text": "The Labrador Retriever passes the Cocker Spaniel to open a record 31-year reign — the longest run at No. 1 any breed has ever managed." },
    { "t": 1993, "title": "Rottweiler mania peaks", "text": "Rottweiler registrations hit roughly 100,000 — No. 2 in America — before the boom collapses to under 25,000 within a decade." },
    { "t": 2022, "title": "French Bulldog takes the crown", "text": "After a decade of meteoric growth, the Frenchie ends the Lab's 31-year reign to become America's most popular dog." }
  ]
