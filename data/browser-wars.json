  "milestones": [
    { "t": 1996.6, "title": "IE bundled with Windows", "text": "Microsoft ships Internet Explorer free with Windows 95, opening the first browser war against Netscape." },
    { "t": 1998.9, "title": "Netscape sells to AOL", "text": "Crushed by IE, Netscape is bought by AOL for $4.2B; its open-sourced code seeds the Mozilla project." },
    { "t": 2003.0, "title": "IE peaks near 95%", "text": "With Netscape gone, Internet Explorer sits on roughly 19 of every 20 desktops — a near-total monopoly." },
    { "t": 2004.9, "title": "Firefox 1.0 released", "text": "Mozilla's lean, tabbed, pop-up-blocking browser becomes the first real crack in IE's dominance." },
    { "t": 2008.7, "title": "Google launches Chrome", "text": "Chrome debuts with the fast V8 JavaScript engine and a comic-book manifesto. It reaches 10% within two years." },
